# RiiChain v2.0 — POD 专用全链路系统
# 配置文件（生产环境请修改 SECRET_KEY 和 DATABASE_URL）

# 应用
APP_NAME=RiiChain
APP_VERSION=2.0.0
DEBUG=True

# 数据库（开发用 SQLite，生产换 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./riichain.db

# 上传
UPLOAD_DIR=app/static/uploads
MAX_UPLOAD_SIZE=52428800

# 安全
SECRET_KEY=riichain-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS（开发环境允许所有来源）
CORS_ORIGINS=["*"]

# AI / LLM（可选，用于自动生成商品标题/描述）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# 平台对接（按需填写）
# TIKTOK_APP_KEY=
# TIKTOK_APP_SECRET=
# TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/platforms/tiktok/callback

# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=
# SHOPIFY_REDIRECT_URI=http://localhost:8000/api/v1/platforms/shopify/callback
